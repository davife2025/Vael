# ─── Somnia Network ────────────────────────────────────────────
SOMNIA_RPC_URL=https://dream-rpc.somnia.network
SOMNIA_CHAIN_ID=50312
SOMNIA_TESTNET_RPC_URL=https://vsomnia-rpc.somnia.network
SOMNIA_TESTNET_CHAIN_ID=50311

# ─── Deployer Wallet ───────────────────────────────────────────
DEPLOYER_PRIVATE_KEY=0x_your_private_key_here

# ─── Contract Addresses (populated after deploy) ───────────────
VAEL_REGISTRY_ADDRESS=
VAEL_LEDGER_ADDRESS=
VAEL_PASSPORT_ADDRESS=
VAEL_REPUTATION_ADDRESS=

# ─── The Graph ─────────────────────────────────────────────────
GRAPH_NODE_URL=http://localhost:8020
GRAPH_IPFS_URL=http://localhost:5001
SUBGRAPH_NAME=vael/somnia

# ─── Database (Postgres via Prisma) ────────────────────────────
DATABASE_URL=postgresql://vael:vael@localhost:5432/vael_db

# ─── API ───────────────────────────────────────────────────────
API_PORT=4000
API_SECRET=your_api_secret_here
JWT_SECRET=your_jwt_secret_here
CORS_ORIGIN=http://localhost:3000

# ─── Frontend ──────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_SOMNIA_RPC=https://dream-rpc.somnia.network
NEXT_PUBLIC_CHAIN_ID=50312
NEXT_PUBLIC_VAEL_REGISTRY_ADDRESS=
NEXT_PUBLIC_VAEL_PASSPORT_ADDRESS=

# ─── Billing (Stripe) ──────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_your_key
STRIPE_WEBHOOK_SECRET=whsec_your_secret

# ─── Misc ──────────────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=debug
