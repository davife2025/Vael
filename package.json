{
  "name": "vael",
  "version": "0.1.0",
  "private": true,
  "description": "Vael — The agent infrastructure protocol for Somnia",
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm -r --parallel dev",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "clean": "pnpm -r clean && rm -rf node_modules",
    "contracts:compile": "pnpm --filter @vael/contracts compile",
    "contracts:test": "pnpm --filter @vael/contracts test",
    "contracts:deploy": "pnpm --filter @vael/contracts deploy",
    "api:dev": "pnpm --filter @vael/api dev",
    "web:dev": "pnpm --filter @vael/web dev",
    "sdk:build": "pnpm --filter @vael/sdk build"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "prettier": "^3.2.0",
    "eslint": "^8.57.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  }
}
