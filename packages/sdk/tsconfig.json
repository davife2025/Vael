{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir":      "dist",
    "rootDir":     "src",
    "module":      "commonjs",
    "target":      "ES2020",
    "declaration": true,
    "declarationMap": true,
    "sourceMap":   true,
    "strict":      true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true
  },
  "include":  ["src/**/*.ts"],
  "exclude":  ["node_modules", "dist", "**/*.test.ts"]
}
